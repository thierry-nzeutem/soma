# Database
DATABASE_URL=postgresql+asyncpg://soma_user:soma_password@localhost:5432/soma
DATABASE_URL_SYNC=postgresql://soma_user:soma_password@localhost:5432/soma

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# App
APP_NAME=SOMA
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# AI Services (optionnel)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
STORAGE_PATH=./data/uploads
MAX_UPLOAD_SIZE_MB=50
